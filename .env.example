# Flask
FLASK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_DEBUG=1

# Database
# SQLite (default, zero-config, good for a single classroom PC)
DATABASE_URL=sqlite:///instance/attendance.db
# MySQL (production, multi-room deployment) - uncomment and fill in to switch
# DATABASE_URL=mysql+pymysql://attendance_user:password@localhost:3306/attendance_db

# Default admin account created on first run / seed
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@college.edu

# Face recognition tuning
FACE_MATCH_TOLERANCE=0.5
FACE_CAPTURE_COUNT=30
CAMERA_INDEX=0

# Email (Flask-Mail) - used for "Email attendance report to faculty"
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com
